<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="my_robot">
    <xacro:arg name="use_hall_homing" default="true"/>
    <xacro:arg name="can_logging_enabled_on_start" default="true"/>
    <xacro:arg name="trajectory_command_rate_hz" default="100.0"/>
    <xacro:include filename="$(find my_robot_ros2_control)/description/ros2_control/ros2_control_my_robot.xacro" />
    <xacro:include filename="$(find my_robot_ros2_control)/description/urdf/my_robot_with_nozzle.description.urdf.xacro" />

</robot>
